import { Button, LineEdit } from "std-widgets.slint";

component FormField inherits VerticalLayout {
    in property placeholder-text <=> input.placeholder-text;
    in property input-type <=> input.input-type;
    out property text <=> input.text;

    in-out property <string> error: "";
    callback validate(string) -> string;

    public function ok() -> bool {
        return error == "";
    }

    alignment: center;

    input := LineEdit {
        height: 65%;
        edited(text) => {
            error = validate(text);
        }
    }

    Text {
        height: 35%;
        text: error;
    }
}

export component App inherits Window {
    property <string> view: "menu";
    in property <image> video-frame <=> video-display.source;

    pure callback is-port(s: string) -> bool;
    callback start-server() -> string;
    callback start-client(server-ip: string) -> string;

    if view == "menu": HorizontalLayout {
        alignment: center;

        server-form := VerticalLayout {
            private property <string> error: "";

            alignment: center;
            width: 40%;
            spacing: 5px;

            Button {
                text: "Start Server";
                height: 5%;
                clicked => {
                    error = start-server();
                    if (error == "") {
                        root.view = "server";
                    }
                }
            }

            if (error != ""): Text {
                text: error;
            }
        }

        Rectangle {
            width: 7%;
        }

        client-form := VerticalLayout {
            private property <string> error: "";

            alignment: center;
            width: 40%;
            spacing: 5px;

            server-ip-field := FormField {
                height: 7%;
                width: 50%;
                placeholder-text: "Enter server address (e.g. 192.168.1.1)";
                validate(text) => is-socket-address(text) ? "" : "Invalid address";
            }

            Button {
                height: 5%;
                text: "Start Client";
                clicked => {
                    error = "";
                    if (server-ip-field.ok()) {
                        error = start-client(server-ip-field.text);
                        if (error == "") {
                            root.view = "client";
                        }
                    }
                }
            }

            Text {
                text: error;
            }
        }
    }
    callback keyboard-input(key: string, action: string);
    callback escape();
    pure callback is-socket-address(address: string) -> bool;
    forward-focus: scope;

    scope := FocusScope {
        KeyBinding {
            keys: @keys(Escape);
            activated => {
                escape();
                root.view = "menu";
            }
        }

        key-pressed(event) => {
            if (view == "client" && !event.modifiers.meta && !event.modifiers.alt && event.text != "") {
                root.keyboard-input(event.text, "pressed");
            }
            accept
        }
        key-released(event) => {
            if (view == "client" && !event.modifiers.meta && !event.modifiers.alt && event.text != "") {
                root.keyboard-input(event.text, "released");
            }
            accept
        }
    }

    in property <bool> client-connected: false;

    VerticalLayout {
        visible: view == "server";

        VerticalLayout {
            Text {
                text: client-connected ? "Client connected." : "Waiting for client connection...";
            }
        }
    }

    VerticalLayout {
        visible: view == "client";

        video-display := Image { }
    }
}
