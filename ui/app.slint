import { MainMenu } from "./menu.slint";
import { Button } from "std-widgets.slint";
import { FormLayout, FormSubmitButton } from "./form.slint";
import { Role } from "./role.slint";

export enum View { main-menu, streamer, watcher }

export enum KeyAction { press, release }

export component App inherits Window {
    preferred-width: 800px;
    preferred-height: 600px;

    // Enables specific components in a mutually exclusive manner
    out property <View> view: View.main-menu;

    function role-to-view(role: Role) -> View {
        if (role == Role.streamer) { View.streamer } else { View.watcher }
    }

    // Main Menu
    callback start-host(role: Role) -> string;
    callback start-client(host-ip: string) -> { role: Role, error: string };
    pure callback is-socket-address(address: string) -> bool;

    // Input
    callback keyboard-input(key: string, action: KeyAction);
    callback mouse-input(button: PointerEventButton, kind: KeyAction);
    callback mouse-move(delta-x: length, delta-y: length);
    callback scroll-input(delta-x: length, delta-y: length);
    callback escape();

    function should-handle-input(modifiers: KeyboardModifiers) -> bool {
        view == View.watcher && !modifiers.meta && !modifiers.alt
    }

    // Streamer/Watcher
    in property <bool> connected: false;
    in property <image> video-frame <=> watcher.source;

    if view == View.main-menu: MainMenu {
        start-host(role) => {
            let error = root.start-host(role);
            if (error == "") {
                root.view = role-to-view(role);
            }
            error
        }
        start-client(host-ip) => {
            let result = root.start-client(host-ip);
            if (result.error == "") {
                root.view = role-to-view(result.role);
            }
            result.error
        }
        is-socket-address(address) => root.is-socket-address(address);
    }

    forward-focus: scope;

    // Keyboard input
    scope := FocusScope {
        width: 100%;
        height: 100%;

        KeyBinding {
            keys: @keys(F12);
            activated => {
                escape();
                if (root.view == View.main-menu) {
                    root.close();
                } else {
                    root.view = View.main-menu;
                }
            }
        }

        key-pressed(event) => {
            if (should-handle-input(event.modifiers)) {
                root.keyboard-input(event.text.to-lowercase(), KeyAction.press);
            }
            accept
        }
        key-released(event) => {
            if (should-handle-input(event.modifiers)) {
                root.keyboard-input(event.text.to-lowercase(), KeyAction.release);
            }
            accept
        }
    }

    // Mouse input
    touch := TouchArea {
        enabled: view == View.watcher;
        
        width: 100%;
        height: 100%;

        pointer-event(event) => {
            if (should-handle-input(event.modifiers)) {
                if (event.kind == PointerEventKind.down) {
                    root.mouse-input(event.button, KeyAction.press);
                } else if (event.kind == PointerEventKind.up) {
                    root.mouse-input(event.button, KeyAction.release);
                }
                // mouse-move is handled by Rust because Slint only provides absolute mouse coordinates,
                // which means that when playing a first-person shooter remotely (for example),
                // the character could otherwise only turn as much as the window bounds allow
            }
        }

        scroll-event(event) => {
            if (should-handle-input(event.modifiers)) {
                root.scroll-input(event.delta_x, event.delta_y);
            }
            accept
        }
    }

    if (!connected && view != View.main-menu): VerticalLayout {
        alignment: center;

        VerticalLayout {
            Text {
                horizontal-alignment: center;
                vertical-alignment: center;
                text: "Waiting for connection...";
            }
        }
    }
    if (view == View.streamer && connected): VerticalLayout {
        VerticalLayout {
            Text {
                text: "Sharing screen";
            }
        }
    }

    VerticalLayout {
        visible: view == View.watcher && connected;

        watcher := Image { }
    }
}
