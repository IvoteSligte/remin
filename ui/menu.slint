import { FormSubmitButton, FormLayout, FormField } from "form.slint";

export component MainMenu inherits HorizontalLayout {
    alignment: center;

    callback start-server() -> string;
    callback start-client(server-ip: string) -> string;
    pure callback is-socket-address(text: string) -> bool;

    FormLayout {
        FormSubmitButton {
            text: "Host";
            validate => true;
            submit => start-server();
        }
    }

    Rectangle {
        width: 7%;
    }

    FormLayout {
        server-ip-field := FormField {
            height: 7%;
            placeholder-text: "Enter server address (e.g. 192.168.1.1)";
            validate(text) => is-socket-address(text) ? "" : "Invalid address";
        }

        FormSubmitButton {
            text: "Connect";
            validate() => server-ip-field.is-valid();
            submit() => start-client(server-ip-field.text);
        }
    }
}

export component RoleSelectMenu inherits HorizontalLayout {
    alignment: center;

    callback select-role(role: string) -> string;

    FormLayout {
        FormSubmitButton {
            text: "Stream";
            validate() => true;
            submit() => select-role("streamer");
        }
    }

    Rectangle {
        width: 7%;
    }

    FormLayout {
        FormSubmitButton {
            text: "Watch";
            validate => true;
            submit() => select-role("watcher");
        }
    }
}
